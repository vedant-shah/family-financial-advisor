# ── Project data (user-specific, generated at runtime) ───────────────────────
# memory/ and sessions/ hold family financial data — never commit real data.
# Commit the directory structure (README, example files) but not the content.
memory/family/
memory/members/
memory/working/
sessions/
cache/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

